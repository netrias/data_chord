# =============================================================================
# Data Chord Environment Configuration
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# The .env file is loaded at app startup with override=True, so values here
# take precedence over any existing environment variables.
# =============================================================================

# Set to "true" for local development (disables static file caching)
DEV_MODE=true

# -----------------------------------------------------------------------------
# Data Model Store Configuration
# -----------------------------------------------------------------------------
# Required: Data model key for fetching CDEs and permissible values.
# This determines which ontology/data model is used for harmonization.
# Examples: "gc" (Genomic Commons), "ccdi" (CCDI)
#
# IMPORTANT: The application will fail to start if this is not set.
# In Docker, this should be set as a build arg or environment variable.
DATA_MODEL_KEY=gc

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------
# Netrias API key for harmonization service (contact Netrias for access)
NETRIAS_API_KEY=your_api_key_here

# Data Model Store API key (optional - falls back to NETRIAS_API_KEY if not set)
# Use this if the Data Model Store requires a different key than harmonization
# DATA_MODEL_STORE_API_KEY=your_data_model_store_key_here

# -----------------------------------------------------------------------------
# CORS Configuration (optional)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins. Defaults to "*" for local dev.
# For production, set explicit origins: https://app.example.com
# CORS_ALLOW_ORIGINS=*
